{
  "expo": {
    "name": "DropSafe",
    "slug": "dropsafe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dropsafe",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
